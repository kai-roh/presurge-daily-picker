<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.presurge.intraday</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>cd /Users/seop/presurge-daily-picker &amp;&amp; set -a &amp;&amp; source .env &amp;&amp; set +a &amp;&amp; python3 -m scripts.run_intraday_monitor --loop</string>
    </array>

    <!-- 22:20 KST = 미국 서머타임 정규장 10분 전. 겨울에는 약 70분 대기 후 시작. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>22</integer>
        <key>Minute</key>
        <integer>20</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/seop/presurge-daily-picker/data/intraday_launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/seop/presurge-daily-picker/data/intraday_launchd_stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/seop/presurge-daily-picker</string>
</dict>
</plist>
