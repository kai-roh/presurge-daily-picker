# Polygon.io (시세, ticker reference)
POLYGON_API_KEY=

# Anthropic Claude API (8-K 분류 + 일일 리포트)
ANTHROPIC_API_KEY=
CLAUDE_REPORT_MODEL=claude-haiku-4-5
CLAUDE_CLASSIFY_MODEL=claude-sonnet-4-6

# Finnhub (분석가 PT, 뉴스)
FINNHUB_API_KEY=

# Telegram bot (push)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_CHAT_ID=

# SEC EDGAR User-Agent (필수)
SEC_USER_AGENT="presurge-picker contact@example.com"

# DB (SQLite local 또는 Supabase)
DATABASE_URL=sqlite:///data/presurge.db
# 로컬 SQLite -> Supabase 1회 migration 때 사용. GitHub secret에는 DATABASE_URL로 등록.
SUPABASE_DATABASE_URL=
# SUPABASE_DATABASE_URL에 psql 명령을 넣는 경우 migration script가 이 값을 사용해 URI를 구성.
SUPABASE_DB_PASSWORD=

# 운영 모드
DRY_RUN=false
LOG_LEVEL=INFO

# 장중 모니터링 MVP
INTRADAY_ENABLED=0
INTRADAY_MAX_TICKERS=20
INTRADAY_INTERVAL_SECONDS=300
INTRADAY_USE_YFINANCE=1
INTRADAY_USE_FINNHUB_FALLBACK=1
INTRADAY_MIN_TIER=3
INTRADAY_MAX_ALERTS_PER_LOOP=5
INTRADAY_BUY_COOLDOWN_MINUTES=30
INTRADAY_REGULAR_SESSION_ONLY=1
