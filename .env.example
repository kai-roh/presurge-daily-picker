# Polygon.io (시세, ticker reference)
POLYGON_API_KEY=

# Anthropic Claude API (8-K 분류 + 일일 리포트)
ANTHROPIC_API_KEY=
CLAUDE_REPORT_MODEL=claude-haiku-4-5
CLAUDE_CLASSIFY_MODEL=claude-sonnet-4-6

# Finnhub (분석가 PT, 뉴스)
FINNHUB_API_KEY=

# Telegram bot (push)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_CHAT_ID=

# SEC EDGAR User-Agent (필수)
SEC_USER_AGENT=presurge-picker contact@example.com

# DB (SQLite local 또는 Supabase)
DATABASE_URL=sqlite:///data/presurge.db

# 운영 모드
DRY_RUN=false
LOG_LEVEL=INFO
